# Copy to .env.local and fill in. All are optional — the app runs without them.

# Canonical site URL, used for OG/social metadata (absolute image URLs).
NEXT_PUBLIC_SITE_URL=https://fullhearts.pro

# Server-host affiliate link. Defaults in-code to our Shockbyte referral
# ($4/sale). Override to swap providers, e.g. BisectHosting:
#   https://www.bisecthosting.com/clients/aff.php?aff=7330
NEXT_PUBLIC_HOST_REF=

# Google AdSense. Leave blank to disable ads entirely (no script, no slots render).
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_RESULTS=
NEXT_PUBLIC_ADSENSE_SLOT_EXPLORE=
