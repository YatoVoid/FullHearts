# Copy to .env.local and fill in. All are optional — the app runs without them.

# Deployment base path. Unset = "/FullHearts" (GitHub Pages project site).
# Set to "" (empty) when moving to a root / custom domain.
NEXT_PUBLIC_BASE_PATH=

# Canonical site URL, used for SEO (sitemap, robots, OG, canonical).
NEXT_PUBLIC_SITE_URL=https://yatovoid.github.io/FullHearts

# Google Search Console HTML-tag verification token (optional).
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# Server-host affiliate links. BisectHosting is the primary CTA (modpack-
# friendly, creator program); Shockbyte ($4/sale) is the budget secondary.
# Defaults are baked in-code; override here to change accounts.
NEXT_PUBLIC_HOST_REF_BISECT=
NEXT_PUBLIC_HOST_REF=

# Google AdSense. Leave blank to disable ads entirely (no script, no slots render).
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_RESULTS=
NEXT_PUBLIC_ADSENSE_SLOT_EXPLORE=
